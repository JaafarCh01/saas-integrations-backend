APP_NAME=Devaito
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-railway-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database — Railway injects these automatically when you add the MySQL plugin
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Filesystem — R2 is S3-compatible
FILESYSTEM_DISK=s3

# Cloudflare R2
# - AWS_ENDPOINT: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# - AWS_URL: your public R2 URL (pub-<hash>.r2.dev or custom domain)
# - AWS_DEFAULT_REGION: "auto" for R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# n8n webhooks (Hetzner — unchanged)
N8N_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/ugc-generator
N8N_WEBHOOK_SECRET=
N8N_WHATSAPP_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/fast-agent
N8N_PROMPT_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/suggest-prompt
N8N_INSTAGRAM_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/instagram
N8N_EMAIL_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/email-poll
N8N_PROSPECT_WEBHOOK_URL=https://n8n.my8automation.xyz/webhook/start-omni-hunt

# Devaito SaaS API
DEVAITO_API_URL=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Unipile (Instagram DM)
UNIPILE_API_KEY=
UNIPILE_API_URL=https://api.unipile.com

# Google AI
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Cron protection
CRON_SECRET=
